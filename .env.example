# Shared
NODE_ENV=development
APP_ENV=local

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_OIDC_ISSUER=https://example.auth0.com/
NEXT_PUBLIC_OIDC_CLIENT_ID=web-client-id
NEXT_PUBLIC_FEATURE_SIMULATIONS=false
NEXT_PUBLIC_FEATURE_MANEUVERS=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_LOG_LEVEL=INFO
API_SECRET_KEY=replace-me
API_ALLOWED_ORIGINS=http://localhost:3000
OIDC_ISSUER=https://example.auth0.com/
OIDC_AUDIENCE=sdmps-api

# Database
POSTGRES_DB=sdmps
POSTGRES_USER=sdmps
POSTGRES_PASSWORD=sdmps
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://sdmps:sdmps@localhost:5432/sdmps

# Redis
REDIS_URL=redis://localhost:6379/0

# Feeds
CELESTRAK_BASE_URL=https://celestrak.org/NORAD/elements
SPACETRACK_BASE_URL=https://www.space-track.org
TLE_POLL_INTERVAL_MINUTES=60
TLE_STALE_THRESHOLD_MINUTES=240
